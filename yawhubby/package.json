{
  "name": "kaaf-noticeboard-backend",
  "version": "2.2.0",
  "description": "Enterprise-grade Backend for KAAF University Digital Campus Noticeboard, Event Management System, and Event Tracking Platform",
  "main": "server.js",
  "type": "commonjs",
  "private": false,
  "scripts": {
    "start": "cross-env NODE_ENV=production node server.js",
    "dev": "cross-env NODE_ENV=development nodemon server.js",
    "dev:debug": "cross-env NODE_ENV=development nodemon --inspect server.js",
    "dev:sms": "cross-env SMS_ENABLED=true NODE_ENV=development nodemon server.js",
    "dev:worker": "cross-env NODE_ENV=development node workers/queueWorker.js",
    "dev:cron": "cross-env NODE_ENV=development node scripts/cronJobs.js",
    "dev:backup": "cross-env NODE_ENV=development node scripts/backupService.js",
    "dev:monitor": "cross-env NODE_ENV=development node scripts/performanceMonitor.js",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:worker\" \"npm run dev:cron\" \"npm run dev:monitor\"",
    "production": "cross-env NODE_ENV=production node server.js",
    "production:cluster": "cross-env NODE_ENV=production node cluster.js",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:restart": "pm2 restart ecosystem.config.js",
    "pm2:reload": "pm2 reload ecosystem.config.js",
    "pm2:delete": "pm2 delete ecosystem.config.js",
    "pm2:logs": "pm2 logs",
    "pm2:monit": "pm2 monit",
    "pm2:status": "pm2 status",
    "pm2:save": "pm2 save",
    "pm2:startup": "pm2 startup",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "jest --config jest.integration.config.js",
    "test:e2e": "jest --config jest.e2e.config.js",
    "test:performance": "jest --config jest.performance.config.js",
    "test:load": "artillery run load-test.yml",
    "test:unit": "jest --testMatch='**/tests/unit/**/*.test.js'",
    "test:staged": "jest --findRelatedTests",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:strict": "eslint . --max-warnings 0",
    "lint:staged": "lint-staged",
    "format": "prettier --write \"**/*.{js,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{js,json,md,yml,yaml}\"",
    "seed": "node scripts/seed.js",
    "seed:dev": "cross-env NODE_ENV=development node scripts/seed.js",
    "seed:prod": "cross-env NODE_ENV=production node scripts/seed.js",
    "seed:sms": "node scripts/seedSMSLogs.js",
    "seed:jobs": "node scripts/seedJobLogs.js",
    "seed:all": "npm run seed && npm run seed:sms && npm run seed:jobs",
    "db:reset": "node scripts/resetDB.js",
    "db:migrate": "node scripts/migrate.js",
    "db:migrate:down": "node scripts/migrate.js --down",
    "db:migrate:status": "node scripts/migrate.js --status",
    "db:backup": "node scripts/backupDB.js",
    "db:restore": "node scripts/restoreDB.js",
    "db:optimize": "node scripts/optimizeDB.js",
    "db:validate": "node scripts/validateDB.js",
    "db:stats": "node scripts/dbStats.js",
    "validate": "npm run lint && npm run test",
    "precommit": "npm run lint-staged",
    "prepush": "npm run test",
    "clean": "rm -rf node_modules package-lock.json && npm cache clean --force && npm install",
    "clean:windows": "rd /s /q node_modules && del package-lock.json && npm cache clean --force && npm install",
    "clean:all": "npm run clean && rm -rf logs uploads backups certificates test-results coverage",
    "clean:logs": "rm -rf logs/*.log logs/archives/*",
    "clean:uploads": "rm -rf uploads/*",
    "clean:backups": "rm -rf backups/*",
    "security:check": "npm audit",
    "security:fix": "npm audit fix",
    "security:check:detailed": "npm audit --json > audit-report.json",
    "security:scan": "npx snyk test",
    "security:license": "npx license-checker --summary",
    "docker:build": "docker build -t kaaf-noticeboard-backend .",
    "docker:build:no-cache": "docker build --no-cache -t kaaf-noticeboard-backend .",
    "docker:run": "docker-compose up",
    "docker:run:detach": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:clean": "docker-compose down -v --rmi all",
    "docker:prod": "docker-compose -f docker-compose.prod.yml up -d",
    "docker:shell": "docker exec -it kaaf-noticeboard-backend /bin/sh",
    "docs": "jsdoc -c jsdoc.json",
    "docs:serve": "npx serve docs",
    "docs:generate": "node scripts/generateDocs.js",
    "docs:open": "open docs/index.html",
    "swagger": "node scripts/generate-swagger.js",
    "swagger:serve": "node scripts/serve-swagger.js",
    "swagger:open": "open http://localhost:3000/api-docs",
    "monitor": "node scripts/performanceMonitor.js",
    "monitor:once": "node scripts/performanceMonitor.js --once",
    "monitor:report": "node scripts/performanceMonitor.js --report",
    "monitor:stats": "node scripts/performanceMonitor.js --stats",
    "monitor:alerts": "node scripts/alertManager.js",
    "monitor:dashboard": "node scripts/monitorDashboard.js",
    "queue:monitor": "node scripts/queueMonitor.js",
    "queue:flush": "node scripts/flushQueues.js",
    "queue:retry": "node scripts/retryFailedJobs.js",
    "queue:stats": "node scripts/queueStats.js",
    "cache:clear": "node scripts/clearCache.js",
    "cache:warm": "node scripts/warmCache.js",
    "cache:stats": "node scripts/cacheStats.js",
    "sms:retry": "node scripts/retryFailedSMS.js",
    "sms:stats": "node scripts/smsStats.js",
    "sms:test": "node scripts/testSMS.js",
    "sms:cleanup": "node scripts/cleanupSMSLogs.js",
    "cron:start": "node scripts/cronJobs.js",
    "cron:stop": "pm2 stop kaaf-noticeboard-cron",
    "cron:restart": "pm2 restart kaaf-noticeboard-cron",
    "cron:status": "pm2 status kaaf-noticeboard-cron",
    "prestart": "npm run db:migrate",
    "preproduction": "npm run security:check && npm run db:migrate",
    "health": "node scripts/healthCheck.js",
    "health:detailed": "node scripts/healthCheck.js --detailed",
    "health:json": "node scripts/healthCheck.js --json",
    "info": "node scripts/systemInfo.js",
    "info:detailed": "node scripts/systemInfo.js --detailed",
    "info:json": "node scripts/systemInfo.js --json",
    "backup:create": "node scripts/backupService.js --backup",
    "backup:full": "node scripts/backupService.js --backup --full",
    "backup:incremental": "node scripts/backupService.js --backup --incremental",
    "backup:restore": "node scripts/backupService.js --restore",
    "backup:list": "node scripts/backupService.js --list",
    "backup:cleanup": "node scripts/backupService.js --cleanup",
    "backup:stats": "node scripts/backupService.js --stats",
    "backup:verify": "node scripts/verifyBackup.js",
    "logs:tail": "tail -f logs/app.log",
    "logs:error": "tail -f logs/error.log",
    "logs:worker": "tail -f logs/worker-out.log",
    "logs:cron": "tail -f logs/cron-out.log",
    "logs:monitor": "tail -f logs/monitor-out.log",
    "logs:backup": "tail -f logs/backup-out.log",
    "logs:all": "tail -f logs/*.log",
    "logs:analyze": "node scripts/analyzeLogs.js",
    "logs:rotate": "node scripts/logRotate.js --once",
    "logs:rotate:force": "node scripts/logRotate.js --force",
    "logs:cleanup": "node scripts/logRotate.js --cleanup",
    "maintenance:on": "node scripts/maintenanceMode.js --on",
    "maintenance:off": "node scripts/maintenanceMode.js --off",
    "maintenance:status": "node scripts/maintenanceMode.js --status",
    "analytics:daily": "node scripts/generateDailyAnalytics.js",
    "analytics:weekly": "node scripts/generateWeeklyAnalytics.js",
    "analytics:monthly": "node scripts/generateMonthlyAnalytics.js",
    "analytics:custom": "node scripts/generateCustomAnalytics.js",
    "report:daily": "node scripts/generateDailyReport.js",
    "report:weekly": "node scripts/generateWeeklyReport.js",
    "report:monthly": "node scripts/generateMonthlyReport.js",
    "report:export": "node scripts/exportReport.js",
    "update:check": "npx npm-check-updates",
    "update:apply": "npx npm-check-updates -u && npm install",
    "update:apply:force": "npx npm-check-updates -u && npm install --force",
    "env:validate": "node scripts/validateEnv.js",
    "env:example": "node scripts/generateEnvExample.js",
    "setup": "npm install && npm run env:validate && npm run db:migrate && npm run seed:dev",
    "setup:prod": "npm install --production && npm run env:validate && npm run db:migrate && npm run seed:prod",
    "status": "node scripts/status.js",
    "status:all": "node scripts/status.js --all"
  },
  "keywords": [
    "university",
    "noticeboard",
    "event-management",
    "event-tracking",
    "digital-campus",
    "kaaf-university",
    "real-time",
    "socketio",
    "express",
    "mongodb",
    "redis",
    "jwt-authentication",
    "rest-api",
    "nodejs",
    "mongoose",
    "sms-gateway",
    "textbee",
    "web-push",
    "notifications",
    "queue-worker",
    "cron-jobs",
    "backup",
    "monitoring",
    "enterprise",
    "logging",
    "analytics"
  ],
