  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup.js"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/tests/fixtures/",
      "/coverage/",
      "/dist/",
      "/scripts/",
      "/uploads/",
      "/logs/",
      "/backups/",
      "/certificates/",
      "/workers/"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 75,
        "lines": 75,
        "statements": 75
      }
    },
    "testMatch": [
      "**/tests/**/*.test.js",
      "**/tests/**/*.spec.js"
    ],
    "collectCoverageFrom": [
      "**/*.js",
      "!server.js",
      "!cluster.js",
      "!workers/**/*.js",
      "!**/config/**/*.js",
      "!**/migrations/**/*.js",
      "!**/scripts/**/*.js",
      "!**/tests/**/*.js",
      "!**/node_modules/**",
      "!**/coverage/**",
      "!**/uploads/**",
      "!**/logs/**",
      "!**/backups/**",
      "!**/certificates/**"
    ],
    "verbose": true,
    "testTimeout": 30000,
    "reporters": [
      "default",
      "jest-junit",
      "jest-html-reporter"
    ],
    "jest-junit": {
      "outputDirectory": "./test-results",
      "outputName": "junit.xml"
    },
    "jest-html-reporter": {
      "outputPath": "./test-results/test-report.html",
      "includeFailureMsg": true,
      "includeConsoleLog": true,
      "pageTitle": "KAAF Noticeboard Test Report"
    },
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1",
      "^@config/(.*)$": "<rootDir>/config/$1",
      "^@controllers/(.*)$": "<rootDir>/controllers/$1",
      "^@models/(.*)$": "<rootDir>/models/$1",
      "^@routes/(.*)$": "<rootDir>/routes/$1",
      "^@middleware/(.*)$": "<rootDir>/middleware/$1",
      "^@utils/(.*)$": "<rootDir>/utils/$1",
      "^@services/(.*)$": "<rootDir>/services/$1",
      "^@workers/(.*)$": "<rootDir>/workers/$1"
    }
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write",
      "npm run test:staged"
    ],
    "*.json": [
      "prettier --write"
    ],
    "*.md": [
      "prettier --write"
    ],
    "*.yml": [
      "prettier --write"
    ],
    "*.yaml": [
      "prettier --write"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "pre-push": "npm run test"
    }
  },
  "nodemonConfig": {
    "watch": [
      "server.js",
      "cluster.js",
      "config",
      "controllers",
      "models",
      "routes",
      "middleware",
      "utils",
      "services",
      "workers"
    ],
    "ignore": [
      "node_modules",
      "logs",
      "uploads",
      "coverage",
      "test-results",
      "backups",
      "certificates",
      "temp",
      "tmp",
      "*.test.js",
      "*.spec.js"
    ],
    "ext": "js,json",
        "delay": 2500,
    "env": {
      "NODE_ENV": "development"
    },
    "events": {
      "start": "echo '🚀 Server starting...'",
      "crash": "echo '💥 Server crashed!'",
      "restart": "echo '🔄 Server restarting...'"
    },
    "verbose": true,
    "exitcrash": true
  },
  "browserslist": {
    "production": [
      "node >= 18"
    ],
    "development": [
      "node >= 18"
    ]
  },
  "os": [
    "linux",
    "darwin",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "overrides": {
    "mongoose": "^7.8.9",
    "express": "^4.22.1",
    "cross-spawn": "^7.0.5"
  },
  "workspaces": [
    "packages/*"
  ],
  "files": [
    "server.js",
    "cluster.js",
    "config/",
    "controllers/",
    "models/",
    "routes/",
    "middleware/",
    "utils/",
    "services/",
    "workers/",
    "templates/",
    "scripts/",
    "locales/",
    "public/",
    "ecosystem.config.js",
    "Dockerfile",
    "docker-compose.yml",
    "README.md",
    "LICENSE"
  ],
  "directories": {
    "lib": ".",
    "test": "tests",
    "doc": "docs"
  }
}

