  "dependencies": {
    "@bull-board/api": "^6.21.2",
    "@bull-board/express": "^6.21.2",
    "@sentry/node": "^10.48.0",
    "adm-zip": "^0.5.16",
    "archiver": "^7.0.1",
    "artillery": "^2.0.0-31",
    "axios": "^1.15.0",
    "bcryptjs": "^2.4.3",
    "bull": "^4.16.5",
    "bull-board": "^1.7.2",
    "canvas": "^3.2.3",
    "check-disk-space": "^3.4.0",
    "compression": "^1.8.1",
    "concurrently": "^8.2.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "cron-parser": "^4.9.0",
    "cross-env": "^7.0.3",
    "dotenv": "^16.6.1",
    "exceljs": "^4.4.0",
    "express": "^4.22.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.5.1",
    "express-session": "^1.19.0",
